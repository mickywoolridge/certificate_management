# Optional mock data: `npm run db:seed` (after migrations).
#
# PostgreSQL — local: run once `npm run db:bootstrap` (uses sudo + local Postgres on 5432).
# Railway: add the Postgres plugin and copy DATABASE_URL.
DATABASE_URL="postgresql://certificate_management_app:PASSWORD@localhost:5432/certificate_management_local"

# Public URL of this app (used in notification emails)
APP_URL="https://your-app.up.railway.app"
NEXT_PUBLIC_APP_URL="https://your-app.up.railway.app"

# Protect the cron endpoint; send as Authorization: Bearer <CRON_SECRET> or x-cron-secret header
CRON_SECRET="generate-a-long-random-string"

# Optional: email via Resend (https://resend.com). Without these, dev logs only; production needs them to send mail.
RESEND_API_KEY=""
EMAIL_FROM="SSL Alerts <onboarding@resend.dev>"
