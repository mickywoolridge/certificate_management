generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum NoticeUnit {
  DAYS
  WEEKS
  MONTHS
}

model Certificate {
  id                     String      @id @default(uuid())
  objectTypeId           String
  objectType             ObjectType  @relation(fields: [objectTypeId], references: [id], onDelete: Restrict)
  system                 String
  name                   String
  startDate              DateTime
  endDate                DateTime
  description            String?
  ownerName              String
  ownerEmail             String
  noticeQuantity         Int
  noticeUnit             NoticeUnit
  /// Set when the owner was notified that this certificate entered its notice window (once per renewal cycle).
  noticeEntryNotifiedAt  DateTime?
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt

  @@index([objectTypeId])
  @@index([endDate])
  @@index([ownerEmail])
}

model ObjectType {
  id           String        @id @default(uuid())
  name         String        @unique
  slug         String        @unique
  isActive     Boolean       @default(true)
  certificates Certificate[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([isActive])
}
