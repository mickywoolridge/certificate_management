{
  "name": "certificate_management",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/prisma-generate-with-fallback.cjs && next build",
    "start": "next start",
    "postinstall": "node scripts/prisma-generate-with-fallback.cjs",
    "db:bootstrap": "bash scripts/bootstrap-local-postgres.sh",
